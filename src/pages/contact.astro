---
import Base from '../layouts/Base.astro';
---

<Base title="Contact - Chuck McAndrew" description="Get in touch with Chuck McAndrew.">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="font-mono text-base text-primary mb-8">~/contact</h1>

    <div class="space-y-4">
      <a href="mailto:chuck@chuckmcandrew.com" class="flex items-center gap-3 bg-base-200 border border-surface-border rounded-lg p-4 no-underline hover:border-primary/30 transition-colors group">
        <span class="font-mono text-primary text-sm">email</span>
        <span class="text-text-secondary text-sm group-hover:text-base-content transition-colors">chuck@chuckmcandrew.com</span>
      </a>

      <a href="https://github.com/dcmcand" class="flex items-center gap-3 bg-base-200 border border-surface-border rounded-lg p-4 no-underline hover:border-primary/30 transition-colors group">
        <span class="font-mono text-primary text-sm">github</span>
        <span class="text-text-secondary text-sm group-hover:text-base-content transition-colors">dcmcand</span>
      </a>

      <a href="https://www.linkedin.com/in/chuck-mcandrew-93194674/" class="flex items-center gap-3 bg-base-200 border border-surface-border rounded-lg p-4 no-underline hover:border-primary/30 transition-colors group">
        <span class="font-mono text-primary text-sm">linkedin</span>
        <span class="text-text-secondary text-sm group-hover:text-base-content transition-colors">chuck-mcandrew</span>
      </a>
    </div>
  </div>
</Base>
