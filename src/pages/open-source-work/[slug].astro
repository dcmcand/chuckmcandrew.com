---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('openSourceWork');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const statusClass = {
  production: 'badge-success',
  active: 'badge-info',
  deprecated: 'badge-ghost',
}[project.data.status] ?? 'badge-ghost';
---

<Base
  title={`${project.data.name} - Chuck McAndrew`}
  description={project.data.shortDescription}
>
  <article class="max-w-[680px] mx-auto px-6 pt-12 pb-16">
    <nav class="font-mono text-xs text-text-secondary mb-5" aria-label="Breadcrumb">
      <a href="/open-source-work" class="text-primary no-underline hover:underline">~/open-source-work</a>
      <span> / </span>
      <span>{project.id}</span>
    </nav>

    <header>
      <h1 class="text-3xl font-bold leading-tight mb-4">{project.data.name}</h1>
      <div class="flex items-center gap-3 mb-4">
        <span class={`badge badge-sm ${statusClass}`}>{project.data.status}</span>
        <span class="font-mono text-xs text-text-secondary">{project.data.role}</span>
      </div>
      <div class="flex flex-wrap gap-2 mb-6">
        {project.data.tech.map((t: string) => (
          <span class="font-mono text-xs px-2 py-1 rounded text-primary bg-accent-dim">{t}</span>
        ))}
      </div>
      <div class="flex gap-3 mb-8">
        {project.data.github && (
          <a
            href={project.data.github}
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-sm px-3 py-1.5 rounded border border-surface-border text-primary hover:bg-base-200 transition-colors no-underline"
          >
            GitHub
          </a>
        )}
        {project.data.site && (
          <a
            href={project.data.site}
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-sm px-3 py-1.5 rounded bg-primary text-base-100 hover:opacity-90 transition-opacity no-underline"
          >
            Site
          </a>
        )}
      </div>
    </header>

    <div class="prose-custom">
      <Content />
    </div>
  </article>
</Base>
